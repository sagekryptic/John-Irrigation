</header>

<main id="top">

  <div class="hero-section">
    <div class="hero device-panel">
      <span class="screw tl"></span><span class="screw tr"></span><span class="screw bl"></span><span class="screw br"></span>
      <div class="lcd">SYSTEM STATUS: ONLINE — RIVERVIEW, FL</div>
