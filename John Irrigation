<script>
  // Scroll reveal
  const revealEls = document.querySelectorAll('.reveal');
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (reduceMotion) {
    revealEls.forEach(el => el.classList.add('in-view'));
  } else {
    const io = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('in-view');
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });
    revealEls.forEach(el => io.observe(el));
  }

  // Diagnostic scanner
  const scenarios = [
    {
      node: 0,
      title: "Wrong zone kept firing",
      detail: "Two valve wires were crossed inside the controller, so the timer watered the wrong section every cycle.",
      fix: "Isolated the wiring by testing one valve at a time, then corrected the connection at the controller.",
      time: "Solved same visit"
    },
    {
      node: 1,
      title: "Pressure was low, system-wide",
      detail: "No puddle, no visible break — just weak coverage everywhere, the kind of leak that only shows up on the water bill.",
      fix: "Traced a slow mainline leak, repaired the pipe, then purged and rebalanced every head.",
      time: "Found in under 5 minutes"
    },
    {
      node: 2,
      title: "The controller looked fine. The valve wasn't.",
      detail: "The timer was firing right on schedule, but a stuck valve kept one entire zone from ever turning on.",
      fix: "Replaced the valve and two worn heads on the same line while it was open.",
      time: "Solved same visit"
    },
    {
      node: 3,
      title: "A head went quiet months ago",
      detail: "It wasn't broken on the surface — it was buried, and the pipe underneath had been cut clean through.",
      fix: "Dug down to the head, spliced the cut line, and restored full pressure to the zone.",
      time: "Solved same visit"
    },
    {
      node: 4,
      title: "Tree roots seized a sprinkler body",
      detail: "Roots had grown completely around the housing over several seasons, cracking it from the outside in.",
      fix: "Freed the body without cutting the roots, swapped the housing, and tested for full flow.",
      time: "Solved same visit"
    }
  ];

  let current = -1;
  const btn = document.getElementById('diagBtn');
  const beam = document.getElementById('scanBeam');
  const resultCard = document.getElementById('diagResult');
  const nodes = document.querySelectorAll('.node');

  function runDiagnostic(){
    btn.disabled = true;
    btn.textContent = 'Scanning…';
    resultCard.classList.remove('show');
    nodes.forEach(n => n.classList.remove('active'));

    beam.classList.remove('active');
    void beam.offsetWidth; // force reflow so the animation restarts
    beam.classList.add('active');

    current = (current + 1) % scenarios.length;
    const scenario = scenarios[current];
    const duration = reduceMotion ? 60 : 1450;

    setTimeout(() => {
      const activeNode = document.querySelector('.node[data-i="' + scenario.node + '"]');
      if (activeNode) activeNode.classList.add('active');

      resultCard.querySelector('.diag-title').textContent = scenario.title;
      resultCard.querySelector('.diag-detail').textContent = scenario.detail;
      resultCard.querySelector('.diag-fix').textContent = scenario.fix;
      resultCard.querySelector('.diag-time').textContent = scenario.time;
      resultCard.classList.add('show');

      btn.disabled = false;
      btn.textContent = 'Run diagnostic again';
    }, duration);
  }

  btn.addEventListener('click', runDiagnostic);
</script>

