            <g class="node" data-i="1" transform="translate(300,80)">
              <circle r="34" class="node-circle"/>
              <text class="node-label" y="6">MAIN</text>
            </g>
            <g class="node" data-i="2" transform="translate(490,80)">
              <circle r="34" class="node-circle"/>
              <text class="node-label" y="6">VALVE</text>
            </g>
            <g class="node" data-i="3" transform="translate(680,80)">
              <circle r="34" class="node-circle"/>
              <text class="node-label" y="6">HEAD</text>
            </g>
            <g class="node" data-i="4" transform="translate(870,80)">
              <circle r="32" class="node-circle"/>
              <text class="node-label" y="6" font-size="11">ROOT</text>
            </g>
          </svg>
        </div>

        <div class="diag-bottom">
          <button class="btn btn-brass" id="diagBtn">Run 60-second diagnostic</button>
        </div>

        <div class="diag-result" id="diagResult">
          <div class="diag-field title" style="grid-column:1/-1;">
            <label>Diagnosis</label>
            <p class="diag-title"></p>
          </div>
          <div class="diag-field">
            <label>What was actually wrong</label>
            <p class="diag-detail"></p>
