<style>
  :root{
    --paper:#F2F6F4;
    --paper-deep:#E4EDE8;
    --ink:#12312D;
    --ink-soft:#4A6560;
    --teal:#1B6E6E;
    --teal-deep:#0E4A4A;
    --teal-pale:#D9EAE8;
    --lawn:#4C7A3D;
    --lawn-pale:#E4EEDD;
    --brass:#C17817;
    --brass-deep:#9C5C10;
    --brass-light:#E8B34D;
    --clay:#B84B2B;
    --clay-pale:#F3DED4;
    --white:#FBFDFC;
    --font-display:'Big Shoulders Display', sans-serif;
    --font-body:'Inter', sans-serif;
    --font-mono:'IBM Plex Mono', monospace;
    --maxw:1120px;
  }
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
  html{scroll-behavior:smooth;}
  body{
    font-family:var(--font-body);
    background:var(--paper);
    color:var(--ink);
    line-height:1.6;
    -webkit-font-smoothing:antialiased;
  }
  img,svg{display:block;max-width:100%;}
  a{color:inherit;}
  :focus-visible{outline:3px solid var(--brass-light);outline-offset:3px;}
  .wrap{max-width:var(--maxw);margin:0 auto;padding-inline:24px;}
  .eyebrow{
    font-family:var(--font-mono);
    font-size:0.72rem;
    letter-spacing:0.14em;
    text-transform:uppercase;
    color:var(--teal);
    font-weight:500;
    display:inline-flex;
    align-items:center;
    gap:8px;
  }
  .eyebrow::before{
    content:"";
    width:8px;height:8px;border-radius:50%;
    background:var(--lawn);
    display:inline-block;
  }
  h1,h2,h3{
    font-family:var(--font-display);
    font-weight:700;
    letter-spacing:-0.01em;
    line-height:1.05;
  }
  .btn{
    font-family:var(--font-body);
    font-weight:600;
    font-size:0.95rem;
    border-radius:8px;
    padding:14px 24px;
    display:inline-flex;
    align-items:center;
    justify-content:center;
    gap:8px;
    border:2px solid transparent;
    cursor:pointer;
    text-decoration:none;
    transition:transform .15s ease, box-shadow .15s ease, background .15s ease;
  }
  .btn:active{transform:translateY(2px);}
  .btn-brass{
    background:var(--brass-deep);
    color:var(--white);
  }
  .btn-brass:hover{background:var(--brass);box-shadow:0 6px 18px rgba(156,92,16,0.35);}
  .btn-outline{
    background:transparent;
    border-color:rgba(251,253,252,0.55);
    color:var(--white);
  }
  .btn-outline:hover{border-color:var(--white);background:rgba(251,253,252,0.08);}
  .btn-outline-ink{
    background:transparent;
    border-color:var(--teal-deep);
    color:var(--teal-deep);
  }
  .btn-outline-ink:hover{background:var(--teal-pale);}
  .btn:disabled{opacity:0.6;cursor:progress;}

  /* device panel motif: screws at corners, like real equipment */
  .device-panel{position:relative;}
  .screw{
    position:absolute;width:9px;height:9px;border-radius:50%;
    background:rgba(251,253,252,0.35);
    box-shadow:inset 0 1px 1px rgba(0,0,0,0.4);
  }
  .screw.tl{top:14px;left:14px;} .screw.tr{top:14px;right:14px;}
  .screw.bl{bottom:14px;left:14px;} .screw.br{bottom:14px;right:14px;}

  /* NAV */
  header.nav{
    position:sticky;top:0;z-index:50;
    background:rgba(242,246,244,0.9);
    backdrop-filter:blur(8px);
    border-bottom:1px solid var(--paper-deep);
  }
  .nav-inner{
    max-width:var(--maxw);margin:0 auto;padding:14px 24px;
    display:flex;align-items:center;justify-content:space-between;gap:16px;
  }
  .logo{display:flex;align-items:center;gap:10px;text-decoration:none;color:var(--ink);}
  .logo-mark{width:30px;height:30px;flex:none;}
  .logo-text{font-family:var(--font-display);font-weight:800;font-size:1.15rem;letter-spacing:-0.01em;line-height:1;}
  .logo-text span{color:var(--brass-deep);}
  .nav-links{display:flex;gap:28px;font-size:0.92rem;font-weight:500;}
  .nav-links a{text-decoration:none;color:var(--ink-soft);transition:color .15s;}
  .nav-links a:hover{color:var(--teal-deep);}
  @media (max-width:800px){.nav-links{display:none;}}

  /* HERO */
  .hero-section{padding:28px 24px 0;}
  .hero{
    max-width:var(--maxw);margin:0 auto;
    background:linear-gradient(155deg, var(--teal-deep), #0A3838 80%);
    border-radius:20px;
    color:var(--white);
    padding:clamp(40px,7vw,76px) clamp(24px,6vw,64px);
    overflow:hidden;
  }
  .lcd{
    font-family:var(--font-mono);
    font-size:0.78rem;
    letter-spacing:0.1em;
    color:var(--brass-light);
    background:rgba(0,0,0,0.22);
    border:1px solid rgba(232,179,77,0.3);
    display:inline-block;
    padding:7px 14px;
    border-radius:6px;
    margin-bottom:22px;
  }
  .rating-row{
    display:flex;align-items:center;gap:10px;flex-wrap:wrap;
    margin-bottom:18px;color:rgba(251,253,252,0.85);font-size:0.95rem;
  }
  .stars{color:var(--brass-light);letter-spacing:2px;font-size:1rem;}
  .hero h1{font-size:clamp(2.3rem,5vw,4rem);max-width:16ch;margin-bottom:20px;}
  .hero p.lede{
    max-width:52ch;color:rgba(251,253,252,0.82);font-size:1.08rem;margin-bottom:32px;
  }
  .hero-ctas{display:flex;gap:14px;flex-wrap:wrap;}

  /* SECTIONS shared */
  section{padding:clamp(56px,9vw,96px) 24px;}
  .section-inner{max-width:var(--maxw);margin:0 auto;}
  .section-head{max-width:60ch;margin-bottom:44px;}
  .section-head h2{font-size:clamp(1.9rem,3.4vw,2.7rem);margin-top:10px;margin-bottom:14px;}
  .section-head p{color:var(--ink-soft);font-size:1.05rem;}

  .reveal{opacity:0;transform:translateY(18px);transition:opacity .6s ease, transform .6s ease;}
  .reveal.in-view{opacity:1;transform:translateY(0);}

  /* DIAGNOSTIC */
  .diagnostic-section{background:var(--white);}
  .diag-panel{
    background:var(--paper);
    border:1px solid var(--paper-deep);
    border-radius:18px;
    padding:clamp(20px,4vw,40px);
  }
  .diag-top{
    display:flex;justify-content:space-between;align-items:center;gap:16px;flex-wrap:wrap;
    margin-bottom:28px;
  }
  .diag-svg-wrap{position:relative;margin-bottom:8px;}
  .diagnostic-svg{width:100%;height:auto;}
  .pipe-line{stroke:var(--paper-deep);stroke-width:4;stroke-linecap:round;}
  .node-circle{
    fill:var(--paper);
    stroke:var(--teal-deep);
    stroke-width:3;
    transition:fill .3s, stroke .3s;
  }
  .node-label{
    font-family:var(--font-mono);
    font-size:12px;
    font-weight:600;
    fill:var(--teal-deep);
    text-anchor:middle;
    letter-spacing:0.04em;
    transition:fill .3s;
  }
  .node.active .node-circle{fill:var(--clay-pale);stroke:var(--clay);}
  .node.active .node-label{fill:var(--clay);}
  .node.active{animation:pulse 1s ease;}
  @keyframes pulse{
    0%{transform:scale(1);} 30%{transform:scale(1.12);} 100%{transform:scale(1);}
  }
  .scan-beam{
    position:absolute;left:0;top:6%;height:88%;width:5px;
    background:linear-gradient(var(--teal), var(--lawn));
    box-shadow:0 0 22px var(--teal);
    border-radius:3px;
    opacity:0;
    transform:translateX(0);
    transition:transform 1.4s cubic-bezier(.65,0,.35,1), opacity .2s;
  }
  .scan-beam.active{opacity:1;transform:translateX(calc(100% - 5px));}
  .diag-svg-wrap{overflow:hidden;border-radius:10px;}
  .diag-bottom{display:flex;justify-content:center;margin:20px 0 28px;}
  .diag-result{
    display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
    gap:20px;
    background:var(--teal-pale);
    border-radius:14px;
    padding:24px;
    opacity:0;max-height:0;overflow:hidden;
    transition:opacity .4s ease;
  }
  .diag-result.show{opacity:1;max-height:600px;padding:24px;}
  .diag-field label{
    display:block;font-family:var(--font-mono);font-size:0.68rem;letter-spacing:0.1em;
    text-transform:uppercase;color:var(--teal-deep);margin-bottom:6px;
  }
  .diag-field p{font-size:0.95rem;color:var(--ink);}
  .diag-field.title p{font-family:var(--font-display);font-weight:700;font-size:1.3rem;line-height:1.15;}
  .diag-time{color:var(--lawn);font-weight:600;}

  /* ZONES */
  .zones-section{background:var(--paper-deep);}
  .zones-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:18px;}
  .zone-card{
    background:var(--white);
    border-radius:14px;
    padding:26px;
    border:1px solid rgba(18,49,45,0.08);
    transition:transform .2s ease, box-shadow .2s ease;
  }
  .zone-card:hover, .zone-card:focus-within{
    transform:translateY(-4px);
    box-shadow:0 14px 30px rgba(18,49,45,0.1);
  }
  .zone-top{display:flex;align-items:center;gap:14px;margin-bottom:12px;}
  .zone-num{
    font-family:var(--font-mono);font-weight:600;font-size:0.85rem;
    color:var(--white);background:var(--teal);
    width:34px;height:34px;border-radius:8px;
    display:flex;align-items:center;justify-content:center;flex:none;
  }
  .zone-icon{width:22px;height:22px;color:var(--brass-deep);transition:transform .5s ease;}
  .zone-card:hover .zone-icon, .zone-card:focus-within .zone-icon{transform:rotate(18deg) scale(1.1);}
  .zone-card h3{font-size:1.15rem;font-weight:700;margin-bottom:8px;font-family:var(--font-body);letter-spacing:0;}
  .zone-card p{color:var(--ink-soft);font-size:0.95rem;}

  /* WHY */
  .why-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:20px;}
  .stat-card{
    background:var(--white);border-radius:14px;padding:28px;
    border:1px solid rgba(18,49,45,0.08);
  }
  .stat-card .num{font-family:var(--font-display);font-size:2.6rem;font-weight:800;color:var(--teal-deep);line-height:1;margin-bottom:10px;}
  .stat-card .label{color:var(--ink-soft);font-size:0.92rem;}

  /* TESTIMONIALS */
  .testimonials-section{background:var(--teal-deep);color:var(--white);}
  .testimonials-section .section-head p{color:rgba(251,253,252,0.75);}
  .testimonials-section .eyebrow{color:var(--brass-light);}
  .testimonials-section .eyebrow::before{background:var(--brass-light);}
  .t-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:18px;}
  .t-card{
    background:rgba(251,253,252,0.06);
    border:1px solid rgba(251,253,252,0.14);
    border-radius:14px;padding:24px;
  }
  .t-card p.quote{font-size:0.98rem;margin-bottom:16px;color:rgba(251,253,252,0.92);}
  .t-card .who{font-family:var(--font-mono);font-size:0.74rem;letter-spacing:0.05em;color:var(--brass-light);}

  /* INFO / CONTACT */
  .info-section{background:var(--paper);}
  .info-grid{display:grid;grid-template-columns:1.1fr 0.9fr;gap:40px;}
  @media (max-width:820px){.info-grid{grid-template-columns:1fr;}}
  .info-panel{
    background:var(--teal-deep);color:var(--white);
    border-radius:18px;padding:clamp(28px,4vw,40px);
  }
  .info-panel h3{font-size:1.5rem;margin-bottom:18px;}
  .hours-table{width:100%;border-collapse:collapse;font-size:0.95rem;margin-bottom:16px;}
  .hours-table td{padding:7px 0;border-bottom:1px solid rgba(251,253,252,0.12);}
  .hours-table td:first-child{color:rgba(251,253,252,0.7);font-family:var(--font-mono);font-size:0.82rem;}
  .hours-table td:last-child{text-align:right;font-weight:600;}
  .hours-note{font-size:0.82rem;color:rgba(251,253,252,0.6);}
  .contact-panel{display:flex;flex-direction:column;gap:20px;}
  .contact-block{background:var(--white);border:1px solid rgba(18,49,45,0.08);border-radius:14px;padding:24px;}
  .contact-block .label{font-family:var(--font-mono);font-size:0.72rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--teal);margin-bottom:8px;}
  .contact-block .value{font-size:1.1rem;font-weight:600;margin-bottom:4px;}
  .badges{display:flex;flex-wrap:wrap;gap:10px;}
  .badge{
    font-family:var(--font-mono);font-size:0.76rem;
    background:var(--lawn-pale);color:var(--lawn);
    padding:8px 12px;border-radius:20px;border:1px solid rgba(76,122,61,0.25);
  }
  .cta-row{display:flex;gap:12px;flex-wrap:wrap;margin-top:6px;}

  footer{
    background:var(--ink);color:rgba(251,253,252,0.65);
    padding:32px 24px;font-size:0.85rem;
  }
  .footer-inner{max-width:var(--maxw);margin:0 auto;display:flex;justify-content:space-between;gap:16px;flex-wrap:wrap;align-items:center;}
  .footer-inner a{color:var(--brass-light);text-decoration:none;}

  @media (prefers-reduced-motion: reduce){
    *,*::before,*::after{
      animation-duration:0.001ms !important;
      animation-iteration-count:1 !important;
      transition-duration:0.001ms !important;
      scroll-behavior:auto !important;
    }
  }
</style>
</head>
<body>

<header class="nav">
  <div class="nav-inner">
    <a href="#top" class="logo">
      <svg class="logo-mark" viewBox="0 0 30 30" aria-hidden="true">
        <path d="M15 3 C15 3 6 14 6 20 A9 9 0 0 0 24 20 C24 14 15 3 15 3 Z" fill="none" stroke="#1B6E6E" stroke-width="2.4" stroke-linejoin="round"/>
